# Environment Variables for AI Agentic Workflow with n8n
# Biến môi trường cho Quy trình Tác nhân AI với n8n

# n8n Configuration
# Cấu hình n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password_here
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh
N8N_SECURE_COOKIE=false

# Database Configuration
# Cấu hình cơ sở dữ liệu
POSTGRES_DB=n8n_workflow
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=your_postgres_password_here

# OpenAI API Configuration
# Cấu hình API OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Gmail API Configuration
# Cấu hình API Gmail
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# Slack API Configuration
# Cấu hình API Slack
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token_here
SLACK_CHANNEL=#complaints-alerts
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Discord API Configuration
# Cấu hình API Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Redis Configuration
# Cấu hình Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Processing Configuration
# Cấu hình xử lý email
EMAIL_CHECK_INTERVAL=300
COMPLAINT_KEYWORDS=phàn nàn,khiếu nại,không hài lòng,thất vọng,lỗi,sự cố
SENTIMENT_THRESHOLD=-0.3

# Notification Configuration
# Cấu hình thông báo
ENABLE_SLACK_NOTIFICATIONS=true
ENABLE_DISCORD_NOTIFICATIONS=false
NOTIFICATION_RETRY_COUNT=3

# Logging Configuration
# Cấu hình ghi nhật ký
LOG_LEVEL=info
ENABLE_WORKFLOW_LOGGING=true
